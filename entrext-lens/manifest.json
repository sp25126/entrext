{
  "manifest_version": 3,
  "name": "Entrext Lens",
  "version": "2.0.0",
  "description": "Professional UI Auditing Engine with 3st-Pass AI Pipeline.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://api.groq.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/index.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "shared/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
